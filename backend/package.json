{
  "name": "job-tracker-api",
  "version": "1.0.0",
  "description": "AI-Powered Job Application Tracker — MongoDB/Mongoose Backend",
  "type": "module",
  "engines": {
    "node": ">=18.0.0"
  },
  "scripts": {
    "dev": "nodemon --watch src --ext js src/server.js",
    "start": "node src/server.js",
    "db:seed": "node src/scripts/db-init.js",
    "db:drop": "DROP_DB=true node src/scripts/db-init.js"
  },
  "dependencies": {
    "bcryptjs": "^2.4.3",
    "cookie-parser": "^1.4.6",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "helmet": "^7.1.0",
    "jsonwebtoken": "^9.0.2",
    "mongoose": "^8.24.0",
    "morgan": "^1.10.0",
    "multer": "^1.4.5-lts.1",
    "openai": "^4.47.1",
    "pdf-parse": "^1.1.1",
    "zod": "^3.23.4"
  },
  "devDependencies": {
    "nodemon": "^3.1.0"
  }
}
